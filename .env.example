# Stripe keys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Security token required by the admin dashboard API
ADMIN_DASHBOARD_TOKEN=replace-with-a-long-random-string

# Public URL of this site (used for Stripe checkout return URLs)
BASE_URL=http://localhost:8080

# Preferred: comma-separated Stripe product IDs used as tip tiers
STRIPE_TIER_PRODUCT_IDS=prod_123,prod_456

# Optional explicit price IDs (used in addition to product IDs)
STRIPE_TIER_PRICE_IDS=price_123,price_456
